<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>InspectGive</AssemblyName>
    <RootNamespace>InspectGive</RootNamespace>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <!-- CSS API version the plugin links against. The orchestrator passes the
         CSS release it just installed (-p:CssApiVersion=...) so the plugin's API
         always matches the runtime; the default keeps a bare `dotnet build` working. -->
    <CssApiVersion Condition="'$(CssApiVersion)' == ''">1.0.369</CssApiVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CounterStrikeSharp.API" Version="$(CssApiVersion)">
      <Private>false</Private>
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="MySqlConnector" Version="2.3.7" />
  </ItemGroup>

  <ItemGroup>
    <!-- Skin-name lookup baked into the DLL so there's no runtime download. -->
    <EmbeddedResource Include="SkinNames.json" />
  </ItemGroup>

</Project>

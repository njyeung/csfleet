# ─── MariaDB ───────────────────────────────────────────────────────────────
# The orchestrator uses these to start the MariaDB container and connect to it.
#
# MariaDB sits on the shared `csfleet` bridge at a fixed address (no host port is
# published). DB_HOST is how the orchestrator, running on the host, dials it — it
# must match maria's static IP on that bridge (see mariaIP in main.go). Game
# server plugins reach maria by container name over the bridge instead, so this
# value does not affect them.
DB_HOST=172.30.0.2
DB_PORT=3306
DB_NAME=csfleet
DB_USER=csfleet
DB_PASS=csfleet
DB_ROOT_PASS=csfleet

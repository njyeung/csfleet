# DB_* environment variables are seeded to start the MariaDB container
# and injected into the DB on startup.
# DB_* vars are the only env vars that are stored outside the database
# since we need the DB credentials to connect to it in the first place.  
# DB_HOST is the Docker IP of the container.

DB_HOST=172.30.0.2
DB_PORT=3306
DB_NAME=csfleet
DB_USER=csfleet
DB_PASS=csfleet
DB_ROOT_PASS=csfleet


# Admin credentials are seeded here. Other user accounts
# can be created once logged in as Admin.

ADMIN_USER=root
ADMIN_PASS=csfleet
JWT_SECRET=csfleet


# Your domain for https (note: if you point a domain at your address,
# make sure to leave port 80 and 443 open)
# Leave empty to run regular http
TLS_DOMAINS=panel.example.com
# optional, recommended for expiry notices
TLS_EMAIL=myemail@example.com  
# persist this if you want don't want to risk Let's Encrypt rate limits
TLS_CACHE_DIR=/var/lib/csfleet/autocert
